MCP_DB_NAME=brainx_mcp
JWT_SECRET=replace_with_at_least_32_byte_secret
JPA_DDL_AUTO=update

# MCP OAuth protected resource settings.
# 배포에서는 PUBLIC_BASE_URL=${PUBLIC_BASE_URL}, BRAINX_OAUTH_ISSUER=${PUBLIC_BASE_URL},
# BRAINX_MCP_RESOURCE=${PUBLIC_BASE_URL}/mcp 로 사용합니다.
PUBLIC_BASE_URL=http://localhost:3000
BRAINX_OAUTH_ISSUER=http://localhost:3000
BRAINX_MCP_RESOURCE=http://localhost:3000/mcp
BRAINX_MCP_PROTECTED_RESOURCE_METADATA_URL=http://localhost:3000/.well-known/oauth-protected-resource

WORKSPACE_SERVICE_URL=http://localhost:8082
INTELLIGENCE_SERVICE_URL=http://localhost:8086
WORKSPACE_SERVICE_TIMEOUT=5s
INTELLIGENCE_SERVICE_TIMEOUT=10s
