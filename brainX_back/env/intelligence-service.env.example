SERVER_PORT=8086
INTELLIGENCE_DB_NAME=intelligence_service
# Full apps profile uses Discovery service names. For standalone IDE runs,
# switch these back to localhost URLs or set the matching env vars manually.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/intelligence_service
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
BRAINX_WORKSPACE_BASE_URL=http://localhost:8082
BRAINX_COMMERCE_BASE_URL=http://localhost:8084
BRAINX_COMMERCE_SERVICE_TOKEN=local-service-token
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=2s
BRAINX_VECTOR_QDRANT_ENABLED=false
BRAINX_REPAIR_LEGACY_DEFAULT_DOCUMENT_GROUP_VECTORS_ENABLED=false
BRAINX_REPAIR_LEGACY_DEFAULT_DOCUMENT_GROUP_BACKFILL_ENABLED=false
BRAINX_REPAIR_LEGACY_DEFAULT_DOCUMENT_GROUP_BACKFILL_BATCH_SIZE=200
BRAINX_EVENTS_PRODUCER_ENABLED=false
BRAINX_EVENTS_CONSUMER_ENABLED=false
OPENAI_API_KEY=
BRAINX_NOTE_SUMMARY_MODEL=gpt-5.4-nano
EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://localhost:8761/eureka/
EUREKA_INSTANCE_HOSTNAME=localhost
