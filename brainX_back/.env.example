# 이 파일은 팀원이 참고하는 백엔드 공통 설정 예시입니다.
# 실제 공통 실행 값은 이 파일을 복사해 brainX_back/.env에 작성하세요.
# 서비스별 값은 brainX_back/env/*.env.example을 복사해 작성합니다.
# .env에는 개인 secret이 들어갈 수 있으므로 Git에 올리면 안 됩니다.

# 세 백엔드 서비스가 공통으로 사용하는 설정입니다.
# JWT_SECRET은 User-Service, Workspace-Service, Ingestion-Service가 반드시 같은 값을 써야 합니다.
# 32바이트 이상 길이의 임의 문자열을 사용하세요.
JWT_SECRET=replace_with_same_32_byte_or_longer_secret_for_all_services
FRONTEND_BASE_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
SERVICE_TOKEN=local-service-token

# Docker Compose가 DB 컨테이너를 만들 때 사용하는 계정/DB 이름입니다.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_local_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_DRIVER=org.postgresql.Driver
JPA_DDL_AUTO=update
USER_DB_NAME=brainx_user
WORKSPACE_DB_NAME=brainx_workspace
INGESTION_DB_NAME=brainx_ingestion
COMMERCE_DB_NAME=brainx_commerce
INTELLIGENCE_DB_NAME=intelligence_service
MCP_DB_NAME=brainx_mcp

# Redis shared cache/session/draft store settings.
# Docker Compose overrides REDIS_HOST to redis for app containers.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=2s

# Neo4j graph projection/read-model settings.
# Docker Compose exposes Browser at http://localhost:7474 and Bolt at localhost:7687.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=brainx_neo4j_local_password
NEO4J_BACKFILL_ON_STARTUP=true
NEO4J_HEAP_INITIAL_SIZE=512m
NEO4J_HEAP_MAX_SIZE=1G
NEO4J_PAGECACHE_SIZE=512m

# Kafka K8S 리스너의 advertised 호스트명(브로커가 클라이언트에 돌려주는 재접속 주소).
# 로컬 Docker Desktop(run.ps1)에서는 이 값을 설정하지 않아 host.docker.internal이 그대로 쓰인다.
# EC2+k3s PoC(run-infra.ps1)에서는 이 값을 kafka.internal로 강제 설정하므로, 이 파일이나
# 로컬 .env에 다른 값을 적어 두어도 run-infra.ps1 실행 시에는 그 값이 우선 적용된다.
KAFKA_K8S_ADVERTISED_HOST=host.docker.internal
