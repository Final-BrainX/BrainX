{
  "name": "brainx-electron",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Electron desktop shell for BrainX",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:main && npm run build:preload",
    "build:renderer": "node ./scripts/build-renderer.mjs",
    "build:app": "npm run build:renderer && npm run build",
    "dev": "concurrently -k \"tsc -p tsconfig.json -w\" \"npm --prefix ../brainx-next run dev\" \"npm run dev:electron\"",
    "dev:electron": "wait-on dist/main/main.js dist/preload/index.js tcp:3000 && electron .",
    "start": "npm run build && electron .",
    "start:bundled": "npm run build:app && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dist:win": "npm run build:app && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.brainx.desktop",
    "productName": "BrainX",
    "compression": "maximum",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "asarUnpack": [
      ".app-bundle/**"
    ],
    "files": [
      "dist/**/*",
      ".app-bundle/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "BrainX",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.2",
    "wait-on": "^8.0.3"
  }
}
