{
  "id": null,
  "uid": "brainx_logs",
  "title": "BrainX Logs",
  "tags": [
    "brainx",
    "logging",
    "loki"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": []
  },
  "editable": false,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({job=\"docker\"}, service)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "stream",
        "label": "Stream",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({service=~\"$service\"}, stream)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Volume by Service",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (count_over_time({job=\"docker\", service=~\"$service\", stream=~\"$stream\"}[$__interval]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error/Exception Log Volume",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (count_over_time({job=\"docker\", service=~\"$service\", stream=~\"$stream\"} |~ \"(?i)(error|exception|fail|timeout)\" [$__interval]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Selected Service Logs",
      "datasource": "Loki",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"docker\", service=~\"$service\", stream=~\"$stream\"}"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Error Focus",
      "datasource": "Loki",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"docker\", service=~\"$service\", stream=~\"$stream\"} |~ \"(?i)(error|exception|fail|timeout)\""
        }
      ]
    }
  ]
}
