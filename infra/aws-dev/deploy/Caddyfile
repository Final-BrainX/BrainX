{$PUBLIC_SITE_ADDRESS} {
	@mcpWellKnown path /.well-known/oauth-protected-resource
	handle @mcpWellKnown {
		reverse_proxy mcp-service:8087
	}

	@mcp path /mcp* /api/v1/mcp/*
	handle @mcp {
		reverse_proxy mcp-service:8087
	}

	@oauth path /oauth/token /oauth/register /.well-known/oauth-authorization-server /.well-known/openid-configuration
	handle @oauth {
		reverse_proxy user-service:8080
	}

	# /api/v1/ai/**, /api/v1/intelligence/** 등은 intelligence-service로 직행시키지 않고
	# gateway-service를 거친다. 게스트 AI 사용 한도는 Gateway의 JwtAuthenticationGlobalFilter가
	# 발급/검증하는 X-Guest-Id 쿠키에 의존하는데, Intelligence-Service의 JwtAuthenticationFilter는
	# 그 헤더를 "Gateway를 거친 요청에서만 신뢰"하도록 만들어져 있다. Caddy가 Gateway를 건너뛰면
	# 게스트 요청엔 Authorization도 X-Guest-Id도 없어 인증 자체가 안 되고, 로그인 사용자에게는
	# Commerce-Service 소유인 /api/v1/ai/usage가 엉뚱하게 intelligence-service로 가서 404가 난다.
	# Gateway-Service가 이미 이 경로들을 전부 올바른 다운스트림(Commerce/Intelligence)으로
	# 라우팅하도록 구성돼 있으므로 아래 공용 /api/v1/* 캐치올에 맡긴다.
	handle /api/v1/* {
		reverse_proxy gateway-service:8088
	}

	handle {
		reverse_proxy frontend:3000
	}
}

{$ADMIN_SITE_ADDRESS} {
	handle /grafana* {
		reverse_proxy grafana:3000
	}

	reverse_proxy admin-frontend:3001
}
