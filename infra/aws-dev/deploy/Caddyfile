{$PUBLIC_SITE_ADDRESS} {
	@mcpWellKnown path /.well-known/oauth-protected-resource
	handle @mcpWellKnown {
		reverse_proxy mcp-service:8087
	}

	@mcp path /mcp* /api/v1/mcp/*
	handle @mcp {
		reverse_proxy mcp-service:8087
	}

	@oauth path /oauth/token /oauth/register /.well-known/oauth-authorization-server /.well-known/openid-configuration
	handle @oauth {
		reverse_proxy user-service:8080
	}

	# /api/v1/ai/usage는 Commerce-Service 소유 엔드포인트라 아래 intelligence 캐치올보다
	# 먼저 gateway-service로 보내야 한다(Gateway-Service의 commerce-service-ai-usage 라우트가
	# 이 경로를 Commerce-Service로 넘겨준다) — 그렇지 않으면 intelligence-service가 받아서 404.
	@aiUsage path /api/v1/ai/usage
	handle @aiUsage {
		reverse_proxy gateway-service:8088
	}

	@intelligence path /api/v1/ai/* /api/v1/intelligence/* /api/v1/notes/*/summary /api/v1/users/me/style-profile
	handle @intelligence {
		reverse_proxy intelligence-service:8086
	}

	handle /api/v1/* {
		reverse_proxy gateway-service:8088
	}

	handle {
		reverse_proxy frontend:3000
	}
}

{$ADMIN_SITE_ADDRESS} {
	handle /grafana* {
		reverse_proxy grafana:3000
	}

	reverse_proxy admin-frontend:3001
}
